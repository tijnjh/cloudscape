{
  "deno.enable": true,
  "deno.enablePaths": ["./deno.json"],
  "prettier.enable": false,
  "editor.defaultFormatter": "denoland.vscode-deno",
  "[svelte]": {
    "editor.defaultFormatter": "denoland.vscode-deno"
  },
  "[typescript]": {
    "editor.defaultFormatter": "denoland.vscode-deno"
  },
  "files.associations": {
    "*.css": "tailwindcss"
  }
}
